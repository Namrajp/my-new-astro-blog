---
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";
import { SITE } from "../config";

const url = new URL(Astro.request.url).pathname;
const { frontmatter, title } = Astro.props;
const isHome = url === "/";
const isBlog = url.startsWith("/blog");
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/branding/favicon-person-circuit.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta
      name="description"
      content={frontmatter?.description ?? SITE.description}
    />
    <meta property="og:image" content={`${SITE.url}/my-image.png`} />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="My cool blog"
      href="/rss.xml"
    />
    <title>{title}</title>

    <style is:global>
      .svg-container {
        max-width: 200px;
        margin: auto;
      }
      .svg-circle:hover + .svg-text-group {
        opacity: 0;
      }
    </style>

    <ClientRouter />
  </head>
  <body class="site-body">
    <div class="page-shell">
      <header id="home">
        <nav class="nav" id="navigation">
          <div class="nav-center" id="nav">
            <div class="nav-header">
              <img
                src="/branding/logo-person-circuit.webp"
                alt="AI logo"
                class="logo"
              />

              <button class="nav-toggle" aria-label="Toggle navigation">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <line x1="3" y1="6" x2="21" y2="6" />
                  <line x1="3" y1="12" x2="21" y2="12" />
                  <line x1="3" y1="18" x2="21" y2="18" />
                </svg>
              </button>
            </div>

            <div class="links-container">
              <ul class="nav-links">
                <li>
                  <a
                    href="/"
                    class:list={[
                      "nav-link",
                      {
                        "is-active": isHome,
                      },
                    ]}
                    >Home</a
                  >
                </li>
                <!-- <li>
                  <a
                    href="/pricing"
                    class={url === "/pricing"
                      ? "font-bold text-gray-800 hover:text-gray-600"
                      : "font-medium text-gray-500 hover:text-gray-900 scroll-link"}
                    >Pricing</a
                  >
                </li> -->
                <li>
                  <a
                    href="/blog/page/1"
                    class:list={[
                      "nav-link",
                      {
                        "is-active": isBlog,
                      },
                    ]}
                    >Blog</a
                  >
                </li>
                <!-- <li>
                  <a
                    href="/login"
                    class={url === "/login"
                      ? "font-bold text-gray-800 hover:text-gray-600"
                      : "font-medium text-gray-500 hover:text-gray-900 scroll-link"}
                    >Login</a
                  >
                </li>
                <li>
                  <a
                    href="/signup"
                    class={url === "/signup"
                      ? "font-bold text-gray-800 hover:text-gray-600"
                      : "font-medium text-gray-500 hover:text-gray-900 scroll-link"}
                    >Signup</a
                  >
                </li> -->
              </ul>
            </div>
          </div>
        </nav>
      </header>
      {
        frontmatter?.title && (
          <h1 class="page-title">
            {frontmatter.title}
          </h1>
        )
      }

      <main class="content-shell">
        <slot />
      </main>

      <footer class="site-footer">
        <nav class="footer-links">
          <a href="/" class="footer-link">Home</a>
          <!-- <a
            href="/pricing"
            class="font-medium text-gray-500 hover:text-gray-900">Pricing</a
          > -->
          <a href="/blog/page/1" class="footer-link">Blog</a>
        </nav>
        <p class="footer-copy">
          &copy; 2026 Great Tool. All rights reserved.
        </p>
      </footer>
    </div>
    <script src="../main.ts"></script>
  </body>
</html>
