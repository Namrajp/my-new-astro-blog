---
import { withBase } from "../utils/paths";

interface Props {
  title: string;
  date: Date;
  slug: string;
  readingTime: number;
}
const { title, date, slug, readingTime } = Astro.props;
---

<li class="flex flex-col gap-2 border-b border-zinc-200 py-4 md:flex-row md:items-center md:justify-between">
  <a
    class="text-left font-semibold text-zinc-900 hover:underline"
    href={withBase(`/blog/${slug}`)}
  >
    {title}
  </a>
  <div class="flex shrink-0 gap-3 text-sm text-zinc-500">
    <span>{readingTime} min read</span>
    <span>{date.toLocaleDateString()}</span>
  </div>
</li>
