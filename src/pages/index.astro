---
import { getCollection } from "astro:content";
import Layout from "@layouts/Layout.astro";
import PostCard from "../components/PostCard.astro";
import TagBadge from "../components/TagBadge.astro";
import { readingTime } from "../utils/readingTime";
import { withBase } from "../utils/paths";

const launchPostPlan = [
  {
    slug: "python-guide",
    note: "Start here if you want one clean Python workflow for day-to-day development.",
  },
  {
    slug: "prompting-guide",
    note: "A practical primer on getting better results from AI tools without guesswork.",
  },
  {
    slug: "claude-commands",
    note: "A useful reference once you are ready to work faster with AI tooling in the CLI.",
  },
  {
    slug: "numpy-guide",
    note: "The fastest way to build intuition for arrays, vectorized math, and scientific Python.",
  },
  {
    slug: "pandas-guide",
    note: "A minimal introduction to structured data work once you are comfortable with Python basics.",
  },
];

const allPosts = await getCollection("posts");
const sortedPosts = allPosts.sort(
  (a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf()
);
const postsBySlug = new Map(sortedPosts.map((post) => [post.id, post]));
const featuredPosts = launchPostPlan.flatMap((item) => {
  const post = postsBySlug.get(item.slug);
  return post ? [{ ...item, post }] : [];
});
const latestPosts = sortedPosts.slice(0, 4);
const startHerePosts = featuredPosts.slice(0, 3);
const tags: string[] = [];

sortedPosts.forEach((post) => {
  post.data.tags.forEach((tag) => {
    if (!tags.includes(tag)) tags.push(tag);
  });
});
---

<Layout
  title="Home"
  description="Start with practical, beginner-friendly guides on Python, AI tools, and everyday developer workflows."
  contentClass="mt-12 mx-auto max-w-6xl px-4 text-left md:px-8"
>
  <section class="grid gap-6 lg:grid-cols-[1.45fr_0.95fr]">
    <div class="rounded-[2rem] border border-zinc-200 bg-white p-8 shadow-sm md:p-10">
      <p class="text-sm font-semibold uppercase tracking-[0.25em] text-emerald-700">
        Blog launch
      </p>
      <h1 class="mt-4 max-w-3xl text-left text-4xl font-black tracking-tight text-zinc-900 md:text-5xl">
        Practical programming guides for developers still building their fundamentals.
      </h1>
      <p class="mt-5 max-w-2xl text-left text-lg text-zinc-700">
        Fix Anything Blog helps beginner to mid-level developers and students learn
        Python, AI tools, and useful workflows through short guides that are meant
        to be applied immediately.
      </p>
      <div class="mt-8 flex flex-wrap gap-4">
        <a
          class="rounded-full bg-zinc-900 px-6 py-3 text-base font-semibold text-white no-underline transition hover:bg-zinc-700"
          href={withBase("/blog/python-guide")}
        >
          Start with Python
        </a>
        <a
          class="rounded-full border border-zinc-300 px-6 py-3 text-base font-semibold text-zinc-900 no-underline transition hover:border-zinc-900"
          href={withBase("/blog/page/1")}
        >
          Browse all posts
        </a>
      </div>
    </div>

    <aside class="rounded-[2rem] border border-emerald-200 bg-emerald-50 p-8">
      <p class="text-sm font-semibold uppercase tracking-[0.25em] text-emerald-700">
        Start here
      </p>
      <p class="mt-4 text-base text-zinc-700">
        If this is your first visit, begin with these posts in order.
      </p>
      <ol class="mt-6 space-y-4">
        {startHerePosts.map(({ post }) => (
          <li class="list-decimal pl-1 text-left">
            <a
              class="font-semibold text-zinc-900 hover:underline"
              href={withBase(`/blog/${post.id}`)}
            >
              {post.data.title}
            </a>
            <p class="mt-1 text-base text-zinc-600">
              {readingTime(post.body ?? "")} min read
            </p>
          </li>
        ))}
      </ol>
    </aside>
  </section>

  <section class="mt-14">
    <div class="flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.25em] text-zinc-500">
          Featured launch posts
        </p>
        <h2 class="mt-3 text-left text-3xl font-black tracking-tight text-zinc-900">
          Five strong entry points for the launch.
        </h2>
      </div>
      <a
        class="text-base font-semibold text-zinc-900 hover:underline"
        href={withBase("/blog/page/1")}
      >
        See the full archive
      </a>
    </div>

    <div class="mt-8 grid gap-6 md:grid-cols-2 xl:grid-cols-3">
      {featuredPosts.map(({ post, note }) => (
        <article class="rounded-[1.75rem] border border-zinc-200 bg-white p-6 shadow-sm">
          <p class="text-sm font-semibold uppercase tracking-[0.2em] text-emerald-700">
            {post.data.tags[0] ?? "guide"}
          </p>
          <h3 class="mt-3 text-left text-2xl font-bold tracking-tight text-zinc-900">
            <a
              class="text-zinc-900 no-underline hover:underline"
              href={withBase(`/blog/${post.id}`)}
            >
              {post.data.title}
            </a>
          </h3>
          <p class="mt-4 text-base text-zinc-700">{note}</p>
          <p class="mt-6 text-sm text-zinc-500">
            {readingTime(post.body ?? "")} min read · {post.data.date.toLocaleDateString()}
          </p>
        </article>
      ))}
    </div>
  </section>

  <section class="mt-14 grid gap-8 lg:grid-cols-[1.15fr_0.85fr]">
    <div class="rounded-[2rem] border border-zinc-200 bg-white p-8 shadow-sm">
      <p class="text-sm font-semibold uppercase tracking-[0.25em] text-zinc-500">
        Latest posts
      </p>
      <h2 class="mt-3 text-left text-3xl font-black tracking-tight text-zinc-900">
        Fresh additions to the blog.
      </h2>
      <ul class="mt-6">
        {latestPosts.map((post) => (
          <PostCard
            title={post.data.title}
            date={post.data.date}
            slug={post.id}
            readingTime={readingTime(post.body ?? "")}
          />
        ))}
      </ul>
    </div>

    <div class="rounded-[2rem] border border-zinc-200 bg-white p-8 shadow-sm">
      <p class="text-sm font-semibold uppercase tracking-[0.25em] text-zinc-500">
        Explore by topic
      </p>
      <h2 class="mt-3 text-left text-3xl font-black tracking-tight text-zinc-900">
        Follow the topics that match your current learning path.
      </h2>
      <div class="mt-6 flex flex-wrap gap-3">
        {tags.map((tag) => <TagBadge tag={tag} />)}
      </div>
    </div>
  </section>
</Layout>
